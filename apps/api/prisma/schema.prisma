generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
  TEST
}

enum AssessmentReviewMode {
  NONE
  SCORE_ONLY
  ANSWERS_NO_EXPLANATIONS
  ANSWERS_WITH_EXPLANATIONS
}

enum ExamSessionStatus {
  WAITING
  ACTIVE
  ENDED
}

enum ExamSessionParticipantStatus {
  JOINED
  APPROVED
}

enum ExamSessionDeviceStatus {
  PENDING
  APPROVED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  firstName           String
  lastName            String
  role                UserRole
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  studentProfile      StudentProfile?
  parentStudentLinks  ParentStudentLink[]  @relation("ParentLinks")
  taughtClasses       SchoolClass[]        @relation("ClassTeacher")
  teachingAssignments TeachingAssignment[] @relation("TeachingAssignmentTeacher")
  createdAssessments  Assessment[]         @relation("AssessmentTeacher")
  examSessions        ExamSession[]        @relation("ExamSessionTeacher")
}

model StudentProfile {
  id                      String                   @id @default(cuid())
  userId                  String                   @unique
  studentNumber           String?                  @unique
  dateOfBirth             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id])
  parentLinks             ParentStudentLink[]
  enrollments             Enrollment[]
  submissions             Submission[]
  results                 Result[]
  examSessionParticipants ExamSessionParticipant[]
}

model ParentStudentLink {
  id               String         @id @default(cuid())
  parentUserId     String
  studentProfileId String
  relationshipType String?
  createdAt        DateTime       @default(now())
  parent           User           @relation("ParentLinks", fields: [parentUserId], references: [id])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([parentUserId, studentProfileId])
}

model SchoolClass {
  id                  String               @id @default(cuid())
  name                String
  subject             String
  schoolYear          String
  gradeLevel          Int?
  classCode           String?
  isActive            Boolean              @default(true)
  teacherId           String
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teacher             User                 @relation("ClassTeacher", fields: [teacherId], references: [id])
  enrollments         Enrollment[]
  assessments         Assessment[]
  teachingAssignments TeachingAssignment[]
}

model Enrollment {
  id                   String         @id @default(cuid())
  schoolClassId        String
  studentProfileId     String
  studentNumberInClass Int?
  enrolledAt           DateTime       @default(now())
  schoolClass          SchoolClass    @relation(fields: [schoolClassId], references: [id])
  studentProfile       StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([schoolClassId, studentProfileId])
  @@unique([schoolClassId, studentNumberInClass])
}

model Subject {
  id                  String               @id @default(cuid())
  name                String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]
}

model TeachingAssignment {
  id            String       @id @default(cuid())
  schoolClassId String
  subjectId     String
  teacherUserId String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  schoolClass   SchoolClass  @relation(fields: [schoolClassId], references: [id])
  subject       Subject      @relation(fields: [subjectId], references: [id])
  teacher       User         @relation("TeachingAssignmentTeacher", fields: [teacherUserId], references: [id])
  assessments   Assessment[]

  @@unique([schoolClassId, subjectId, teacherUserId])
}

model Assessment {
  id                   String               @id @default(cuid())
  schoolClassId        String
  teacherId            String
  teachingAssignmentId String?
  title                String
  description          String?
  type                 AssessmentType
  totalPoints          Int
  publishedAt          DateTime?
  dueAt                DateTime?
  reviewMode           AssessmentReviewMode @default(NONE)
  reviewAvailableAt    DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  schoolClass          SchoolClass          @relation(fields: [schoolClassId], references: [id])
  teacher              User                 @relation("AssessmentTeacher", fields: [teacherId], references: [id])
  teachingAssignment   TeachingAssignment?  @relation(fields: [teachingAssignmentId], references: [id])
  questions            Question[]
  submissions          Submission[]
  results              Result[]
  examSessions         ExamSession[]
}

model Question {
  id           String             @id @default(cuid())
  assessmentId String
  prompt       String
  type         QuestionType
  maxPoints    Int
  orderIndex   Int
  createdAt    DateTime           @default(now())
  assessment   Assessment         @relation(fields: [assessmentId], references: [id])
  answers      SubmissionAnswer[]

  @@unique([assessmentId, orderIndex])
}

model Submission {
  id               String             @id @default(cuid())
  assessmentId     String
  studentProfileId String
  examSessionId    String?
  status           SubmissionStatus   @default(DRAFT)
  submittedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  assessment       Assessment         @relation(fields: [assessmentId], references: [id])
  studentProfile   StudentProfile     @relation(fields: [studentProfileId], references: [id])
  examSession      ExamSession?       @relation(fields: [examSessionId], references: [id])
  answers          SubmissionAnswer[]
  result           Result?

  @@index([assessmentId, studentProfileId])
  @@index([assessmentId, studentProfileId, examSessionId, status])
}

model SubmissionAnswer {
  id              String     @id @default(cuid())
  submissionId    String
  questionId      String
  answerText      String?
  selectedOption  String?
  pointsAwarded   Int?
  teacherFeedback String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  submission      Submission @relation(fields: [submissionId], references: [id])
  question        Question   @relation(fields: [questionId], references: [id])

  @@unique([submissionId, questionId])
}

model Result {
  id               String         @id @default(cuid())
  submissionId     String         @unique
  assessmentId     String
  studentProfileId String
  totalScore       Int
  maxScore         Int
  percentage       Float?
  gradeLabel       String?
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  submission       Submission     @relation(fields: [submissionId], references: [id])
  assessment       Assessment     @relation(fields: [assessmentId], references: [id])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
}

model ExamSession {
  id           String                   @id @default(cuid())
  assessmentId String
  teacherId    String
  status       ExamSessionStatus        @default(WAITING)
  startsAt     DateTime?
  endedAt      DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  assessment   Assessment               @relation(fields: [assessmentId], references: [id])
  teacher      User                     @relation("ExamSessionTeacher", fields: [teacherId], references: [id])
  participants ExamSessionParticipant[]
  submissions  Submission[]
}

model ExamSessionParticipant {
  id               String                       @id @default(cuid())
  examSessionId    String
  studentProfileId String
  status           ExamSessionParticipantStatus @default(JOINED)
  joinedAt         DateTime                     @default(now())
  approvedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  examSession      ExamSession                  @relation(fields: [examSessionId], references: [id])
  studentProfile   StudentProfile               @relation(fields: [studentProfileId], references: [id])
  device           ExamSessionDevice?

  @@unique([examSessionId, studentProfileId])
}

model ExamSessionDevice {
  id                       String                  @id @default(cuid())
  examSessionParticipantId String                  @unique
  status                   ExamSessionDeviceStatus @default(PENDING)
  deviceCode               String                  @unique
  joinedAt                 DateTime                @default(now())
  approvedAt               DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  participant              ExamSessionParticipant  @relation(fields: [examSessionParticipantId], references: [id])
}

